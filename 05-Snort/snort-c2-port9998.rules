# Custom Snort 3 Detection Rules
# Author: Insiyah
# Project: BOTS v3 Detection Engineering
# Description:
# Detects Command-and-Control (C2) beaconing activity,
# large inbound payload delivery, and suspicious outbound
# communication on non-standard TCP ports.

# Rule 1 - Outbound C2 Beacon
# Detects outbound TCP beacon traffic from the internal network
# to TCP port 9998 using PSH+ACK packets.

alert tcp 192.168.0.0/16 any -> any 9998 (
    msg:"Outbound C2 beacon";
    flags:PA;
    sid:9000001;
    rev:1;
)

# Rule 2 - Inbound C2 Response
# Detects inbound responses from the suspected C2 server.

alert tcp any 9998 -> 192.168.0.0/16 any (
    msg:"Inbound C2 response";
    flags:PA;
    sid:9000002;
    rev:1;
)

# Rule 3 - Large Inbound Payload
# Detects unusually large payloads delivered over the C2 channel.

alert tcp any 9998 -> 192.168.0.0/16 any (
    msg:"Large inbound payload";
    dsize:>1460;
    sid:9000003;
    rev:1;
)

# Rule 4 - Outbound High-Port Connection
# Detects outbound SYN packets to TCP ports 9990-9999,
# which may indicate beaconing or C2 communication over
# non-standard ports.

alert tcp 192.168.0.0/16 any -> any 9990:9999 (
    msg:"Outbound high port";
    flags:S;
    sid:9000005;
    rev:1;
)
